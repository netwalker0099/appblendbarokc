# Copy this file to .env and fill in real values. Never commit .env.

# --- Postgres ---
POSTGRES_USER=blendbar
POSTGRES_PASSWORD=changeme
POSTGRES_DB=blendbar
DATABASE_URL=postgres://blendbar:changeme@db:5432/blendbar

# --- Squarespace (server-side only, never sent to the browser) ---
# API key for pushing contacts/orders out. Unset => the sync layer uses an
# in-process mock instead of calling Squarespace.
SQUARESPACE_API_KEY=
# Shared secret for verifying inbound Squarespace webhook signatures. Unset =>
# the webhook receiver is disabled and returns 503.
SQUARESPACE_WEBHOOK_SECRET=

# --- Operator auth (stand device token) ---
OPERATOR_AUTH_SECRET=changeme

# --- Domain served by Caddy (must have DNS pointed at this host before TLS will issue) ---
DOMAIN=app.theblendbarokc.com
